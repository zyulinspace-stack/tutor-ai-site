---
import Base from '../layouts/Base.astro';
---
<Base title="Страница не найдена — Тьютор AI" description="Такой страницы нет. Вернитесь на главную или загляните в блог.">
  <div class="wrap section" style="text-align:center; padding-top:96px; padding-bottom:96px">
    <h1>404 — такой страницы нет</h1>
    <p class="lead muted">Зато есть блог для репетиторов и разборы заданий ЕГЭ и ОГЭ.</p>
    <div class="cta-row" style="justify-content:center">
      <a class="btn" href="/">На главную</a>
      <a class="btn btn-ghost" href="/blog">В блог</a>
    </div>
  </div>
</Base>
